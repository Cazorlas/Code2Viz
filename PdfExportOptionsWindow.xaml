<Window x:Class="Code2Viz.PdfExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Page Setup" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PDF Page Setup" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: Settings -->
            <StackPanel Grid.Column="0">
                <!-- Paper Size -->
                <TextBlock Text="Paper Size:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,5"/>
                <ComboBox x:Name="ComboPaperSize"
                          Margin="0,0,0,12"
                          SelectionChanged="ComboPaperSize_SelectionChanged"/>

                <!-- Orientation -->
                <TextBlock x:Name="LabelOrientation" Text="Orientation:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,5"/>
                <StackPanel x:Name="OrientationPanel" Margin="0,0,0,12">
                    <RadioButton x:Name="RadioPortrait" Content="Portrait" GroupName="Orientation"
                                 Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,5" IsChecked="True"
                                 Checked="Orientation_Changed"/>
                    <RadioButton x:Name="RadioLandscape" Content="Landscape" GroupName="Orientation"
                                 Foreground="{StaticResource ForegroundBrush}"
                                 Checked="Orientation_Changed"/>
                </StackPanel>

                <!-- Scale -->
                <TextBlock Text="Scale:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="1 unit = " Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TextScale" Width="55" Text="1.0"
                             Background="{StaticResource SecondaryBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="4,3" VerticalAlignment="Center"
                             TextChanged="Setting_Changed"/>
                    <TextBlock Text=" mm" Foreground="{StaticResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Margin -->
                <TextBlock Text="Margin:" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBox x:Name="TextMargin" Width="55" Text="10"
                             Background="{StaticResource SecondaryBackgroundBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="4,3" VerticalAlignment="Center"
                             TextChanged="Setting_Changed"/>
                    <TextBlock Text=" mm" Foreground="{StaticResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>

            <!-- Right column: Preview -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Preview:" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,5" FontSize="11"/>
                <Border Background="#FF1E1E1E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="8">
                    <StackPanel>
                        <Canvas x:Name="PreviewCanvas" Height="200" ClipToBounds="True"/>
                        <TextBlock x:Name="TextInfo" Foreground="{StaticResource MutedForegroundBrush}"
                                   FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TextWarning" Foreground="#FFE06060"
                                   FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource RibbonButtonStyle}" Width="80" Margin="0,0,10,0"/>
            <Button Content="Export" Click="Export_Click" Style="{StaticResource RunButtonStyle}" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
