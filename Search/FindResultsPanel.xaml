<UserControl
    x:Class="Code2Viz.Search.FindResultsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="200"
    d:DesignWidth="400"
    Background="{DynamicResource SecondaryBackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with result count and Clear button -->
        <Border
            Grid.Row="0"
            Padding="8,4"
            Background="{DynamicResource TertiaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="ResultCountText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource ForegroundBrush}"
                        Text="No results" />
                    <TextBlock
                        x:Name="SearchTermText"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource MutedForegroundBrush}"
                        Text="" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        x:Name="ClearButton"
                        Padding="8,4"
                        Click="ClearButton_Click"
                        Content="Clear"
                        Style="{DynamicResource RibbonButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results ListView -->
        <ListView
            x:Name="ResultsListView"
            Grid.Row="1"
            Background="{DynamicResource BackgroundBrush}"
            BorderThickness="0"
            Foreground="{DynamicResource ForegroundBrush}"
            MouseDoubleClick="ResultsListView_MouseDoubleClick"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3399FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#404040" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <!-- File:Line:Column prefix (clickable) -->
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="12"
                            Foreground="#4EC9B0"
                            Cursor="Hand"
                            Text="{Binding FileName, StringFormat='[{0}:'}" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="12"
                            Foreground="#4EC9B0"
                            Cursor="Hand"
                            Text="{Binding LineNumber}" />
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="12"
                            Foreground="#4EC9B0"
                            Cursor="Hand"
                            Text="{Binding Column, StringFormat=':{0}]'}" />
                        <TextBlock
                            Margin="4,0,0,0"
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            FontSize="12"
                            Foreground="{DynamicResource ForegroundBrush}"
                            Text="{Binding LineContent}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- No results message -->
        <TextBlock
            x:Name="NoResultsMessage"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            Foreground="{DynamicResource MutedForegroundBrush}"
            Text="No results found"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
