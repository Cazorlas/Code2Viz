<Window
    x:Class="Code2Viz.Search.FindReplaceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Find and Replace"
    Width="450"
    Height="320"
    MinWidth="400"
    MinHeight="280"
    MaxHeight="500"
    Background="#1E1E1E"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <!-- TextBox Style -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#D4D4D4" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- RadioButton Style -->
        <Style x:Key="ScopeRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Button Style -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F3F46" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C97EA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2D2D30" />
                                <Setter Property="Foreground" Value="#808080" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}" />
        <KeyBinding Key="F3" Command="{Binding FindNextCommand}" />
        <KeyBinding Key="F3" Modifiers="Shift" Command="{Binding FindPreviousCommand}" />
    </Window.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Find TextBox -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="#D4D4D4"
                Text="Find:" />
            <TextBox
                x:Name="FindTextBox"
                Grid.Column="1"
                Style="{StaticResource SearchTextBoxStyle}"
                TextChanged="FindTextBox_TextChanged" />
        </Grid>

        <!-- Replace TextBox -->
        <Grid
            x:Name="ReplaceRow"
            Grid.Row="1"
            Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="#D4D4D4"
                Text="Replace:" />
            <TextBox
                x:Name="ReplaceTextBox"
                Grid.Column="1"
                Style="{StaticResource SearchTextBoxStyle}" />
        </Grid>

        <!-- Options -->
        <GroupBox
            Grid.Row="2"
            Margin="0,0,0,12"
            BorderBrush="#3F3F46"
            Foreground="#D4D4D4"
            Header="Options">
            <StackPanel Margin="8,8,8,4">
                <CheckBox
                    x:Name="CaseSensitiveCheckBox"
                    Content="Case sensitive"
                    Style="{StaticResource OptionCheckBoxStyle}" />
                <CheckBox
                    x:Name="WholeWordCheckBox"
                    Content="Match whole word only"
                    Style="{StaticResource OptionCheckBoxStyle}" />
                <CheckBox
                    x:Name="UseRegexCheckBox"
                    Content="Use regular expressions"
                    Style="{StaticResource OptionCheckBoxStyle}" />
            </StackPanel>
        </GroupBox>

        <!-- Scope -->
        <GroupBox
            Grid.Row="3"
            Margin="0,0,0,12"
            BorderBrush="#3F3F46"
            Foreground="#D4D4D4"
            Header="Scope">
            <StackPanel Margin="8,8,8,4" Orientation="Horizontal">
                <RadioButton
                    x:Name="CurrentFileRadio"
                    Content="Current File"
                    GroupName="Scope"
                    IsChecked="True"
                    Style="{StaticResource ScopeRadioButtonStyle}" />
                <RadioButton
                    x:Name="EntireProjectRadio"
                    Margin="16,4,0,4"
                    Content="Entire Project"
                    GroupName="Scope"
                    Style="{StaticResource ScopeRadioButtonStyle}" />
            </StackPanel>
        </GroupBox>

        <!-- Status -->
        <TextBlock
            x:Name="StatusText"
            Grid.Row="4"
            Margin="0,0,0,12"
            VerticalAlignment="Top"
            FontSize="12"
            Foreground="#808080"
            Text="" />

        <!-- Buttons -->
        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="FindNextButton"
                Click="FindNextButton_Click"
                Content="Find Next"
                IsEnabled="False"
                Style="{StaticResource DialogButtonStyle}" />
            <Button
                x:Name="FindAllButton"
                Click="FindAllButton_Click"
                Content="Find All"
                IsEnabled="False"
                Style="{StaticResource DialogButtonStyle}" />
            <Button
                x:Name="ReplaceButton"
                Click="ReplaceButton_Click"
                Content="Replace"
                IsEnabled="False"
                Style="{StaticResource DialogButtonStyle}" />
            <Button
                x:Name="ReplaceAllButton"
                Click="ReplaceAllButton_Click"
                Content="Replace All"
                IsEnabled="False"
                Style="{StaticResource DialogButtonStyle}" />
            <Button
                Click="CloseButton_Click"
                Content="Close"
                Style="{StaticResource DialogButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
